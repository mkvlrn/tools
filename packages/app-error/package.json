{
  "name": "@mkvlrn/app-error",
  "description": "Map app error codes to HTTP statuses",
  "version": "0.0.3",
  "license": "MIT",
  "type": "module",
  "author": "Mike Valeriano <mkvlrn@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:mkvlrn/tools"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "node",
    "typescript",
    "error",
    "http-error"
