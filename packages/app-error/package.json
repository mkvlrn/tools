    "typecheck": "tsc-files"
  },
  "devDependencies": {
    "@mkvlrn/config": "^3.1.4",
    "@types/node": "^25.3.5",
    "tsc-files": "^1.1.4",
    "tsdown": "0.21.0",
    "typescript": "6.0.1-rc",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "http-status-codes": "^2.3.0"
  }
}
